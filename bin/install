#!/usr/bin/env bash
# bin/install — build the Go chomper binary and symlink it into PATH.
#
# Idempotent: re-run to rebuild + re-link. Pass --target <dir> to
# override the default install location (~/.local/bin).
#
# This differs from the v0.1-bash install in one important way: there
# we symlinked a script and trusted the script to find its lib/ siblings.
# Here we build a single self-contained binary and symlink that. No
# companion files; no path-resolution loop needed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHOMPER_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

err()  { printf 'error: %s\n' "$*" >&2; }
note() { printf '%s\n' "$*"; }

# --- Parse args ----------------------------------------------------------
TARGET_DIR=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --target)
      [ "$#" -ge 2 ] || { err "--target requires a value"; exit 2; }
      TARGET_DIR="$2"; shift 2 ;;
    --help|-h)
      cat <<'EOF'
Usage: bin/install [--target <dir>]

Builds chomper (Go binary) and symlinks it into ~/.local/bin, then
runs `chomper doctor` to verify the environment.

Pass --target /your/dir to install elsewhere. We deliberately do not
default to /opt/homebrew/bin or /usr/local/bin — those are Homebrew's
prefix on macOS, and a user-installed CLI shouldn't live there.
EOF
      exit 0 ;;
    *)
      err "unknown option: $1"
      exit 2 ;;
  esac
done

# --- Verify go toolchain -------------------------------------------------
if ! command -v go >/dev/null 2>&1; then
  err "go toolchain not found. Install Go (https://go.dev/doc/install) and re-run."
  exit 1
fi

# --- Build the binary ----------------------------------------------------
note "building chomper..."
(cd "$CHOMPER_DIR" && go build -o chomper .)
SOURCE="$CHOMPER_DIR/chomper"
if [ ! -x "$SOURCE" ]; then
  err "build succeeded but $SOURCE is missing or not executable. This shouldn't happen."
  exit 1
fi

# --- Worktree-source warning ---------------------------------------------
git_dir="$(git -C "$CHOMPER_DIR" rev-parse --git-dir 2>/dev/null || true)"
case "$git_dir" in
  *"/worktrees/"*)
    note "warning: installing from a worktree:"
    note "  $CHOMPER_DIR"
    note "  this symlink will break if you 'git worktree remove' this dir."
    note "  Consider merging the branch to main and installing from the main"
    note "  checkout instead."
    echo
    ;;
esac

# --- Choose install location ---------------------------------------------
# Default to ~/.local/bin (user-owned, XDG-style). Auto-create when
# we picked the default; require pre-existence when --target was given.
USER_CHOSE_TARGET=1
if [ -z "$TARGET_DIR" ]; then
  TARGET_DIR="$HOME/.local/bin"
  USER_CHOSE_TARGET=0
fi

if [ ! -d "$TARGET_DIR" ]; then
  if [ "$USER_CHOSE_TARGET" -eq 0 ]; then
    mkdir -p "$TARGET_DIR" || { err "could not create $TARGET_DIR"; exit 1; }
    note "created $TARGET_DIR"
  else
    err "$TARGET_DIR does not exist."
    exit 1
  fi
fi

if [ ! -w "$TARGET_DIR" ]; then
  err "$TARGET_DIR is not writable."
  exit 1
fi

# PATH check
case ":$PATH:" in
  *":$TARGET_DIR:"*) ;;
  *)
    {
      printf 'error: %s is not on your PATH.\n\n' "$TARGET_DIR"
      printf 'Add this to your shell rc (~/.zshrc, ~/.bashrc, ~/.profile):\n'
      printf '  export PATH="$HOME/.local/bin:$PATH"\n\n'
      printf "Then open a new terminal (or 'source' the file) and re-run bin/install.\n"
      printf 'Or pass --target /some/dir/already/on/PATH.\n'
    } >&2
    exit 1
    ;;
esac

TARGET="$TARGET_DIR/chomper"

# --- Link (or relink) ----------------------------------------------------
if [ -L "$TARGET" ]; then
  current="$(readlink "$TARGET")"
  if [ "$current" = "$SOURCE" ]; then
    note "chomper already installed at $TARGET (pointing here)."
  else
    note "replacing existing symlink:"
    note "  $TARGET"
    note "    was: $current"
    note "    now: $SOURCE"
    rm "$TARGET"
    ln -s "$SOURCE" "$TARGET"
  fi
elif [ -e "$TARGET" ]; then
  err "$TARGET exists and is not a symlink. Refusing to overwrite."
  err "Inspect it manually, or pass --target to install elsewhere."
  exit 1
else
  ln -s "$SOURCE" "$TARGET"
  note "installed: $TARGET -> $SOURCE"
fi

# --- Verify on PATH ------------------------------------------------------
echo
if ! command -v chomper >/dev/null 2>&1; then
  err "chomper installed at $TARGET but not visible on PATH."
  err "Restart your shell, or 'source' your rc, or add $TARGET_DIR to PATH."
  exit 1
fi
note "which chomper: $(command -v chomper)"
echo

# --- Hand off to doctor --------------------------------------------------
"$SOURCE" doctor
